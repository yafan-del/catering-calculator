{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "餐饮计算器",
  "version": "1.1.1",
  "identifier": "com.faocn.catering-calculator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "餐饮计算器",
        "width": 600,
        "height": 700,
        "minWidth": 500,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2MzFFMkNEMDA3QjQ3QUYKUldTdlIzc0F6ZUl4aHBFN0tzOHVidWtjckpadVd4aXlsT3V1RlRwbm5aMkJ6ZHc5RDgzVTVUakQK",
      "endpoints": [
        "https://tele-api.faocn.com/catering/app/update-check/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
